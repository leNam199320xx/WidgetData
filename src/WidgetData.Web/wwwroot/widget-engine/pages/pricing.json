{
  "title": "Bảng giá – WidgetData",
  "layout": "flex",
  "auth": { "required": false },
  "widgets": [
    {
      "staticData": {
        "headline": "Bảng giá minh bạch, không phí ẩn",
        "subheadline": "Bắt đầu miễn phí. Nâng cấp khi cần. Huỷ bất kỳ lúc nào."
      },
      "template": "<div class=\"we-hero\" style=\"padding:56px 24px 48px\"><h1 class=\"we-hero-headline\">{{headline}}</h1><p class=\"we-hero-subheadline\">{{subheadline}}</p></div>"
    },
    {
      "staticData": {
        "rows": [
          {
            "name": "Starter",
            "price": "0₫",
            "period": "mãi mãi",
            "featured": "",
            "badge": "",
            "f1": "5 widget",
            "f2": "1 nguồn dữ liệu",
            "f3": "10.000 lượt xem / tháng",
            "f4": "Hỗ trợ cộng đồng",
            "f5": "Widget tĩnh (staticData)",
            "cta": "Bắt đầu ngay"
          },
          {
            "name": "Pro",
            "price": "499.000₫",
            "period": "/ tháng",
            "featured": "we-featured",
            "badge": "<span class=\"we-pricing-badge\">Phổ biến nhất</span>",
            "f1": "Không giới hạn widget",
            "f2": "5 nguồn dữ liệu",
            "f3": "500.000 lượt xem / tháng",
            "f4": "Hỗ trợ email (phản hồi 24h)",
            "f5": "Widget động + cập nhật tự động",
            "cta": "Dùng thử 14 ngày miễn phí"
          },
          {
            "name": "Business",
            "price": "1.499.000₫",
            "period": "/ tháng",
            "featured": "",
            "badge": "",
            "f1": "Không giới hạn widget",
            "f2": "Không giới hạn nguồn dữ liệu",
            "f3": "Không giới hạn lượt xem",
            "f4": "Hỗ trợ riêng (SLA 4 giờ)",
            "f5": "Dashboard nội bộ + phân quyền",
            "cta": "Liên hệ tư vấn"
          }
        ]
      },
      "template": "<div class=\"we-section we-section-center\"><div class=\"we-pricing\">{{#each rows}}<div class=\"we-pricing-card {{featured}}\">{{{badge}}}<div class=\"we-pricing-name\">{{name}}</div><div class=\"we-pricing-price\">{{price}}</div><div class=\"we-pricing-period\">{{period}}</div><ul class=\"we-pricing-features\"><li>{{f1}}</li><li>{{f2}}</li><li>{{f3}}</li><li>{{f4}}</li><li>{{f5}}</li></ul><a class=\"we-btn we-btn-primary\" href=\"#\" style=\"background:#4299e1;color:#fff;border-color:#4299e1;display:block;text-align:center\">{{cta}}</a></div>{{/each}}</div></div>"
    },
    {
      "staticData": {
        "title": "Câu hỏi thường gặp",
        "rows": [
          { "q": "Tôi có thể huỷ gói bất kỳ lúc nào không?",        "a": "Có, bạn có thể huỷ bất cứ lúc nào. Tài khoản sẽ tiếp tục hoạt động đến hết kỳ thanh toán hiện tại." },
          { "q": "Dùng thử miễn phí có cần thẻ tín dụng không?",      "a": "Không. 14 ngày dùng thử hoàn toàn miễn phí, không yêu cầu thông tin thanh toán." },
          { "q": "WidgetData có hỗ trợ nguồn dữ liệu nào?",           "a": "SQL Server, MySQL, PostgreSQL, Oracle, MongoDB, REST API, và CSV. Thêm nguồn mới theo yêu cầu." },
          { "q": "Tôi có thể nhúng widget vào WordPress hay không?",   "a": "Có, WidgetEngine là thư viện JavaScript thuần tuý, nhúng được vào bất kỳ nền tảng web nào." }
        ]
      },
      "template": "<div class=\"we-section\"><h2 class=\"we-section-title\" style=\"text-align:center;margin-bottom:32px\">{{title}}</h2><div style=\"max-width:680px;margin:0 auto\">{{#each rows}}<div style=\"border:1px solid #e2e8f0;border-radius:10px;padding:20px 24px;margin-bottom:14px;background:#fff\"><strong style=\"color:#1a202c;font-size:15px\">{{q}}</strong><p style=\"margin:8px 0 0;color:#718096;font-size:14px;line-height:1.6\">{{a}}</p></div>{{/each}}</div></div>"
    },
    {
      "staticData": {
        "title": "Vẫn còn thắc mắc?",
        "subtitle": "Đội ngũ của chúng tôi luôn sẵn sàng hỗ trợ bạn.",
        "cta": "Chat với chúng tôi"
      },
      "template": "<div class=\"we-section\"><div class=\"we-cta-banner\"><h2 class=\"we-cta-title\">{{title}}</h2><p class=\"we-cta-subtitle\">{{subtitle}}</p><a class=\"we-btn we-btn-cta\" href=\"#\">{{cta}}</a></div></div>"
    }
  ]
}
