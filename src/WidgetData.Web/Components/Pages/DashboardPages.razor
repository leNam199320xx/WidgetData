@page "/pages"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using MudBlazor
@using WidgetData.Application.DTOs
@inject WidgetData.Web.Services.ApiService ApiService
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["DP_Title"] - WidgetData</PageTitle>

<MudText Typo="Typo.h4" Class="mb-1">
    <MudIcon Icon="@Icons.Material.Filled.Dashboard" Class="mr-2" />
    @L["DP_Title"]
</MudText>
<MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-4">
    @L["DP_Subtitle"]
</MudText>

@* Add/Edit Form *@
@if (_showForm)
{
    <MudPaper Class="pa-4 mb-4" Elevation="3">
        <MudText Typo="Typo.h6" Class="mb-3">@(_editingId == null ? L["DP_AddTitle"] : L["DP_EditTitle"])</MudText>
        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_form.Name" Label="@L["DP_PageName"]" Required="true" Variant="Variant.Outlined"
                              HelperText='VD: "Báo cáo doanh thu tháng 1"' />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_form.Description" Label="@L["Description"]" Variant="Variant.Outlined"
                              HelperText="@L["DP_DescHelper"]" />
            </MudItem>
            <MudItem xs="12">
                <MudText Typo="Typo.subtitle2" Class="mb-2">@L["DP_SelectWidgets"]</MudText>
                @if (_allWidgets != null)
                {
                    <MudChipSet T="int" MultiSelection="true" SelectedValues="_selectedWidgetIds"
                                SelectedValuesChanged="@((IReadOnlyCollection<int> ids) => _selectedWidgetIds = ids.ToHashSet())">
                        @foreach (var w in _allWidgets)
                        {
                            <MudChip T="int" Value="@w.Id"
                                     Color="@(_selectedWidgetIds.Contains(w.Id) ? Color.Primary : Color.Default)"
                                     Variant="Variant.Outlined" Size="Size.Small"
                                     Icon="@GetWidgetTypeIcon(w.WidgetType.ToString())">
                                @(w.FriendlyLabel ?? w.Name)
                            </MudChip>
                        }
                    </MudChipSet>
                }
            </MudItem>
            @if (_editingId != null)
            {
                <MudItem xs="12" sm="3">
                    <MudCheckBox @bind-Value="_formIsActive" Label="@L["DP_ActiveLabel"]" Color="Color.Primary" />
                </MudItem>
            }
            <MudItem xs="12">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save" Disabled="_saving" Class="mr-2">
                    @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                    @L["DP_SavePage"]
                </MudButton>
                <MudButton Variant="Variant.Outlined" OnClick="CancelForm">@L["Cancel"]</MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>
}

@* Delete Confirm *@
@if (_deletingItem != null)
{
    <MudPaper Class="pa-4 mb-4" Elevation="3" Style="border-left: 4px solid #f44336">
        <MudText Typo="Typo.h6" Color="Color.Error">@L["ConfirmDelete"]</MudText>
        <MudText Class="mb-3">@L["DP_DeleteConfirm", _deletingItem.Name]</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="DoDelete" Class="mr-2">@L["Delete"]</MudButton>
        <MudButton Variant="Variant.Outlined" OnClick="() => _deletingItem = null">@L["Cancel"]</MudButton>
    </MudPaper>
}

@* Page List *@
@if (_pages != null)
{
    <MudTable Items="_pages" Dense="true" Hover="true" Striped="true">
        <ToolBarContent>
            <MudText Typo="Typo.h6">@L["DP_List"]</MudText>
            <MudSpacer />
            @if (!_showForm)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                           OnClick="OpenAddForm">@L["DP_Create"]</MudButton>
            }
        </ToolBarContent>
        <HeaderContent>
            <MudTh>@L["DP_PageNameCol"]</MudTh>
            <MudTh>@L["Description"]</MudTh>
            <MudTh>@L["DP_WidgetCount", ""]</MudTh>
            <MudTh>@L["Status"]</MudTh>
            <MudTh>@L["Actions"]</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <MudIcon Icon="@Icons.Material.Filled.Dashboard" Size="Size.Small" Class="mr-1" Color="Color.Primary" />
                @context.Name
            </MudTd>
            <MudTd>@(context.Description ?? "-")</MudTd>
            <MudTd>
                <MudChip T="string" Color="Color.Info" Size="Size.Small">@L["DP_WidgetCount", context.WidgetIds.Count]</MudChip>
            </MudTd>
            <MudTd>
                <MudChip T="string" Color="@(context.IsActive ? Color.Success : Color.Error)" Size="Size.Small">
                    @(context.IsActive ? L["Active"] : L["Inactive"])
                </MudChip>
            </MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.GridView" Color="Color.Primary" Size="Size.Small"
                               OnClick="@(() => Nav.NavigateTo($"/pages/builder/{context.Id}"))" Title="@L["DP_BuildPage"]" />
                <MudIconButton Icon="@Icons.Material.Filled.Preview" Color="Color.Success" Size="Size.Small"
                               OnClick="@(() => Nav.NavigateTo($"/reports/preview/{context.Id}"))" Title="@L["DP_Preview"]" />
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Warning" Size="Size.Small"
                               OnClick="() => OpenEditForm(context)" Title="@L["Edit"]" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                               OnClick="() => _deletingItem = context" Title="@L["Delete"]" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error">@_error</MudAlert>
}
else
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}

@code {
    IEnumerable<WidgetGroupDto>? _pages;
    IEnumerable<WidgetDto>? _allWidgets;
    string? _error;
    bool _showForm;
    bool _saving;
    int? _editingId;
    bool _formIsActive = true;
    WidgetGroupDto? _deletingItem;
    HashSet<int> _selectedWidgetIds = new();
    CreateWidgetGroupDto _form = new();

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadPagesAsync(), LoadWidgetsAsync());
    }

    async Task LoadPagesAsync()
    {
        try { _pages = await ApiService.GetDashboardPagesAsync() ?? Array.Empty<WidgetGroupDto>(); }
        catch (Exception ex) { _error = L["DP_FailedToLoad", ex.Message].Value; _pages = Array.Empty<WidgetGroupDto>(); }
    }

    async Task LoadWidgetsAsync()
    {
        try { _allWidgets = await ApiService.GetWidgetsAsync() ?? Array.Empty<WidgetDto>(); }
        catch { _allWidgets = Array.Empty<WidgetDto>(); }
    }

    void OpenAddForm()
    {
        _form = new();
        _selectedWidgetIds = new();
        _editingId = null;
        _formIsActive = true;
        _showForm = true;
    }

    void OpenEditForm(WidgetGroupDto g)
    {
        _editingId = g.Id;
        _form = new CreateWidgetGroupDto { Name = g.Name, Description = g.Description };
        _selectedWidgetIds = g.WidgetIds.ToHashSet();
        _formIsActive = g.IsActive;
        _showForm = true;
    }

    void CancelForm() { _showForm = false; _editingId = null; }

    async Task Save()
    {
        _saving = true;
        try
        {
            _form.WidgetIds = _selectedWidgetIds.ToList();
            if (_editingId == null)
            {
                var result = await ApiService.CreateDashboardPageAsync(_form);
                if (result != null)
                {
                    Snackbar.Add(L["DP_Created"].Value, Severity.Success);
                    _showForm = false;
                    Nav.NavigateTo($"/pages/builder/{result.Id}");
                    return;
                }
                Snackbar.Add(L["FailedCreate"].Value, Severity.Error);
            }
            else
            {
                var dto = new UpdateWidgetGroupDto
                {
                    Name = _form.Name, Description = _form.Description,
                    WidgetIds = _form.WidgetIds, IsActive = _formIsActive
                };
                var result = await ApiService.UpdateDashboardPageAsync(_editingId.Value, dto);
                Snackbar.Add(result != null ? L["DP_Updated"].Value : L["FailedUpdate"].Value, result != null ? Severity.Success : Severity.Error);
            }
            _showForm = false;
            _editingId = null;
            await LoadPagesAsync();
        }
        finally { _saving = false; }
    }

    async Task DoDelete()
    {
        if (_deletingItem == null) return;
        var result = await ApiService.DeleteDashboardPageAsync(_deletingItem.Id);
        Snackbar.Add(result ? L["DP_Deleted"].Value : L["DeleteFailed"].Value, result ? Severity.Success : Severity.Error);
        _deletingItem = null;
        await LoadPagesAsync();
    }

    static string GetWidgetTypeIcon(string type) => type switch
    {
        "Chart" => Icons.Material.Filled.BarChart,
        "Table" => Icons.Material.Filled.TableChart,
        "Metric" => Icons.Material.Filled.Speed,
        "Map" => Icons.Material.Filled.Map,
        _ => Icons.Material.Filled.Widgets
    };
}
