@page "/login"
@layout WidgetData.Web.Components.Layout.AuthLayout
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using MudBlazor
@using WidgetData.Application.DTOs
@inject WidgetData.Web.Services.ApiService ApiService
@inject WidgetData.Web.Services.AuthStateProvider AuthStateProvider
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Login_Title"] - WidgetData</PageTitle>

@if (_checkingSession)
{
    <div class="auth-boot-screen">
        <MudPaper Class="pa-8 auth-boot-card" Elevation="6">
            <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" Class="mb-4" />
            <MudText Typo="Typo.h6" Align="Align.Center">@L["Login_CheckingSession"]</MudText>
        </MudPaper>
    </div>
}
else
{
    <div class="login-page">
        <div class="login-shell">
            <MudPaper Class="login-hero" Elevation="0">
                <MudChip T="string" Color="Color.Primary" Variant="Variant.Filled" Size="Size.Small" Class="mb-4">
                    @L["Login_AdminBadge"]
                </MudChip>
                <MudText Typo="Typo.h3" Class="mb-3">@L["Login_HeroTitle"]</MudText>
                <MudText Typo="Typo.body1" Class="mb-6 auth-hero-copy">
                    @L["Login_HeroDescription"]
                </MudText>

                <MudGrid Class="mb-6">
                    <MudItem xs="12" sm="6">
                        <MudPaper Class="auth-highlight-card" Elevation="0">
                            <MudIcon Icon="@Icons.Material.Filled.Speed" Color="Color.Primary" Class="mb-2" />
                            <MudText Typo="Typo.subtitle1">@L["Login_FastAccessTitle"]</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                @L["Login_FastAccessText"]
                            </MudText>
                        </MudPaper>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudPaper Class="auth-highlight-card" Elevation="0">
                            <MudIcon Icon="@Icons.Material.Filled.Shield" Color="Color.Success" Class="mb-2" />
                            <MudText Typo="Typo.subtitle1">@L["Login_ReturnContextTitle"]</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                @L["Login_ReturnContextText"]
                            </MudText>
                        </MudPaper>
                    </MudItem>
                </MudGrid>

                <MudText Typo="Typo.subtitle2" Class="mb-2">@L["Login_DemoAccountsTitle"]</MudText>
                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="2">
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="@(() => UseDemoAccount("superadmin@widgetdata.com"))">
                        @L["Login_DemoSuperAdmin"]
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="@(() => UseDemoAccount("admin@widgetdata.com"))">
                        @L["Login_DemoAdmin"]
                    </MudButton>
                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" OnClick="@(() => UseDemoAccount("admin@demo.tenant"))">
                        @L["Login_DemoTenantAdmin"]
                    </MudButton>
                </MudStack>
            </MudPaper>

            <MudCard Class="login-card">
                <MudCardHeader Class="pb-0">
                    <CardHeaderContent>
                        <MudText Typo="Typo.h4">@L["Login_Title"]</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">@L["Login_Subtitle"]</MudText>
                    </CardHeaderContent>
                </MudCardHeader>
                <MudCardContent Class="pt-4">
                    @if (!string.IsNullOrWhiteSpace(_safeReturnUrl) && _safeReturnUrl != "/")
                    {
                        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-4">
                            @((MarkupString)string.Format(L["Login_ReturnUrlNotice"].Value, _safeReturnUrl))
                        </MudAlert>
                    }
                    @if (_error != null)
                    {
                        <MudAlert Severity="Severity.Error" Class="mb-4">@_error</MudAlert>
                    }

                    <EditForm Model="_model" OnValidSubmit="HandleLogin">
                        <DataAnnotationsValidator />

                        <MudTextField @bind-Value="_model.Email" For="@(() => _model.Email)" Label="Email"
                                      Variant="Variant.Outlined" InputType="InputType.Email" FullWidth="true"
                                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.AlternateEmail"
                                      Class="mb-3" Disabled="_loading" />
                        <MudTextField @bind-Value="_model.Password" For="@(() => _model.Password)" Label="@L["Login_Password"]"
                                      Variant="Variant.Outlined" FullWidth="true"
                                      InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                                      Adornment="Adornment.End"
                                      AdornmentIcon="@(_showPassword ? Icons.Material.Filled.Visibility : Icons.Material.Filled.VisibilityOff)"
                                      OnAdornmentClick="() => _showPassword = !_showPassword"
                                      Class="mb-2" Disabled="_loading" />
                        <ValidationSummary class="login-validation-summary" />

                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mb-4">
                            @L["Login_DemoHint"]
                        </MudText>

                        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                                   Size="Size.Large" Disabled="_loading">
                            @if (_loading)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            }
                            @L["Login_Title"]
                        </MudButton>
                    </EditForm>
                </MudCardContent>
            </MudCard>
        </div>
    </div>
}

@code {
    private LoginDto _model = new();
    private string _safeReturnUrl = "/";
    string? _error;
    bool _loading;
    bool _showPassword;
    bool _checkingSession = true;

    [SupplyParameterFromQuery(Name = "returnUrl")]
    public string? ReturnUrl { get; set; }

    protected override void OnParametersSet()
    {
        _safeReturnUrl = GetSafeReturnUrl(ReturnUrl);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        try
        {
            var token = await JS.InvokeAsync<string?>("sessionStorage.getItem", "jwt_token");
            if (!string.IsNullOrWhiteSpace(token))
            {
                ApiService.SetToken(token);
                AuthStateProvider.SetUser(token);
                if (AuthStateProvider.IsAuthenticated)
                {
                    Nav.NavigateTo(_safeReturnUrl, replace: true);
                    return;
                }

                await JS.InvokeVoidAsync("sessionStorage.removeItem", "jwt_token");
            }
        }
        catch
        {
            // Ignore bootstrap failures and keep the login page visible.
        }

        ApiService.ClearToken();
        AuthStateProvider.ClearUser();
        _checkingSession = false;
        StateHasChanged();
    }

    async Task HandleLogin()
    {
        _loading = true;
        _error = null;
        try
        {
            var result = await ApiService.LoginAsync(_model);
            if (result?.Token != null)
            {
                await JS.InvokeVoidAsync("sessionStorage.setItem", "jwt_token", result.Token);
                ApiService.SetToken(result.Token);
                AuthStateProvider.SetUser(result.Token);
                Nav.NavigateTo(_safeReturnUrl, replace: true);
            }
            else
            {
                _error = L["Login_InvalidCredentials"].Value;
            }
        }
        catch (Exception ex)
        {
            _error = L["Login_Failed", ex.Message].Value;
        }
        finally
        {
            _loading = false;
        }
    }

    void UseDemoAccount(string email)
    {
        _model.Email = email;
        _error = null;
    }

    static string GetSafeReturnUrl(string? returnUrl)
    {
        if (string.IsNullOrWhiteSpace(returnUrl))
            return "/";

        if (!returnUrl.StartsWith('/')
            || returnUrl.StartsWith("//", StringComparison.Ordinal)
            || returnUrl.Contains('\\'))
            return "/";

        if (returnUrl.Equals("/login", StringComparison.OrdinalIgnoreCase))
            return "/";

        return returnUrl;
    }
}
