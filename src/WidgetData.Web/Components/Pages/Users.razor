@page "/users"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using MudBlazor
@using WidgetData.Application.DTOs
@inject WidgetData.Web.Services.ApiService ApiService

<PageTitle>Users - WidgetData</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Users</MudText>

@if (_users != null)
{
    <MudTable Items="_users" Dense="true" Hover="true" Striped="true">
        <HeaderContent>
            <MudTh>Email</MudTh>
            <MudTh>Display Name</MudTh>
            <MudTh>Roles</MudTh>
            <MudTh>Status</MudTh>
            <MudTh>Last Login</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Email</MudTd>
            <MudTd>@context.DisplayName</MudTd>
            <MudTd>@string.Join(", ", context.Roles)</MudTd>
            <MudTd><MudChip T="string" Color="@(context.IsActive ? Color.Success : Color.Error)" Size="Size.Small">@(context.IsActive ? "Active" : "Inactive")</MudChip></MudTd>
            <MudTd>@(context.LastLoginAt.HasValue ? context.LastLoginAt.Value.ToString("g") : "Never")</MudTd>
        </RowTemplate>
    </MudTable>
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error">@_error</MudAlert>
}
else
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}

@code {
    IEnumerable<UserDto>? _users;
    string? _error;

    protected override async Task OnInitializedAsync()
    {
        try { _users = await ApiService.GetUsersAsync() ?? Array.Empty<UserDto>(); }
        catch (Exception ex) { _error = $"Failed to load users: {ex.Message}"; _users = Array.Empty<UserDto>(); }
    }
}
