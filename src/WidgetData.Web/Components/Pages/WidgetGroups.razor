@page "/widget-groups"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using MudBlazor
@using WidgetData.Application.DTOs
@inject WidgetData.Web.Services.ApiService ApiService
@inject ISnackbar Snackbar

<PageTitle>Widget Groups - WidgetData</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">
    <MudIcon Icon="@Icons.Material.Filled.FolderSpecial" Class="mr-2" />
    Nhóm Widget
</MudText>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
    Phân nhóm các widget để dễ quản lý và phân quyền theo nhóm.
</MudText>

@if (_showForm)
{
    <MudPaper Class="pa-4 mb-4" Elevation="3">
        <MudText Typo="Typo.h6" Class="mb-3">@(_editingId == null ? "Tạo nhóm mới" : "Chỉnh sửa nhóm")</MudText>
        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_form.Name" Label="Tên nhóm" Required="true" Variant="Variant.Outlined"
                              HelperText="Đặt tên ngắn gọn, dễ nhớ (VD: Báo cáo doanh thu)" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_form.Description" Label="Mô tả" Variant="Variant.Outlined"
                              HelperText="Giải thích ngắn gọn nhóm này dùng để làm gì" />
            </MudItem>
            <MudItem xs="12">
                <MudText Typo="Typo.subtitle2" Class="mb-2">Chọn widget vào nhóm này:</MudText>
                @if (_widgets != null)
                {
                    <MudChipSet T="int" MultiSelection="true" SelectedValues="_selectedWidgetIds"
                                SelectedValuesChanged="@((IReadOnlyCollection<int> ids) => _selectedWidgetIds = ids.ToHashSet())">
                        @foreach (var w in _widgets)
                        {
                            <MudChip T="int" Value="@w.Id" Color="@(_selectedWidgetIds.Contains(w.Id) ? Color.Primary : Color.Default)"
                                     Variant="Variant.Outlined" Size="Size.Small">
                                @(w.FriendlyLabel ?? w.Name)
                            </MudChip>
                        }
                    </MudChipSet>
                }
            </MudItem>
            @if (_editingId != null)
            {
                <MudItem xs="12" sm="3">
                    <MudCheckBox @bind-Value="_formIsActive" Label="Đang hoạt động" Color="Color.Primary" />
                </MudItem>
            }
            <MudItem xs="12">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save" Disabled="_saving" Class="mr-2">
                    @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                    Lưu
                </MudButton>
                <MudButton Variant="Variant.Outlined" OnClick="CancelForm">Hủy</MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>
}

@if (_deletingItem != null)
{
    <MudPaper Class="pa-4 mb-4" Elevation="3" Style="border-left: 4px solid #f44336">
        <MudText Typo="Typo.h6" Color="Color.Error">Xác nhận xóa</MudText>
        <MudText Class="mb-3">Xóa nhóm <strong>@_deletingItem.Name</strong>?</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="DoDelete" Class="mr-2">Xóa</MudButton>
        <MudButton Variant="Variant.Outlined" OnClick="() => _deletingItem = null">Hủy</MudButton>
    </MudPaper>
}

@if (_groups != null)
{
    <MudTable Items="_groups" Dense="true" Hover="true" Striped="true">
        <ToolBarContent>
            <MudText Typo="Typo.h6">Danh sách nhóm</MudText>
            <MudSpacer />
            @if (!_showForm)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                           OnClick="OpenAddForm">Tạo nhóm</MudButton>
            }
        </ToolBarContent>
        <HeaderContent>
            <MudTh>Tên nhóm</MudTh>
            <MudTh>Mô tả</MudTh>
            <MudTh>Số widget</MudTh>
            <MudTh>Trạng thái</MudTh>
            <MudTh>Thao tác</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <MudIcon Icon="@Icons.Material.Filled.Folder" Size="Size.Small" Class="mr-1" Color="Color.Warning" />
                @context.Name
            </MudTd>
            <MudTd>@(context.Description ?? "-")</MudTd>
            <MudTd>
                <MudChip T="string" Color="Color.Info" Size="Size.Small">@context.WidgetIds.Count widget</MudChip>
            </MudTd>
            <MudTd>
                <MudChip T="string" Color="@(context.IsActive ? Color.Success : Color.Error)" Size="Size.Small">
                    @(context.IsActive ? "Hoạt động" : "Tạm dừng")
                </MudChip>
            </MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Warning" Size="Size.Small"
                               OnClick="() => OpenEditForm(context)" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                               OnClick="() => _deletingItem = context" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error">@_error</MudAlert>
}
else
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}

@code {
    IEnumerable<WidgetGroupDto>? _groups;
    IEnumerable<WidgetDto>? _widgets;
    string? _error;
    bool _showForm;
    bool _saving;
    int? _editingId;
    bool _formIsActive = true;
    WidgetGroupDto? _deletingItem;
    HashSet<int> _selectedWidgetIds = new();
    CreateWidgetGroupDto _form = new();

    protected override async Task OnInitializedAsync()
    {
        await Task.WhenAll(LoadGroupsAsync(), LoadWidgetsAsync());
    }

    async Task LoadGroupsAsync()
    {
        try { _groups = await ApiService.GetWidgetGroupsAsync() ?? Array.Empty<WidgetGroupDto>(); }
        catch (Exception ex) { _error = $"Không thể tải danh sách nhóm: {ex.Message}"; _groups = Array.Empty<WidgetGroupDto>(); }
    }

    async Task LoadWidgetsAsync()
    {
        try { _widgets = await ApiService.GetWidgetsAsync() ?? Array.Empty<WidgetDto>(); }
        catch { _widgets = Array.Empty<WidgetDto>(); }
    }

    void OpenAddForm()
    {
        _form = new();
        _selectedWidgetIds = new();
        _editingId = null;
        _formIsActive = true;
        _showForm = true;
    }

    void OpenEditForm(WidgetGroupDto g)
    {
        _editingId = g.Id;
        _form = new CreateWidgetGroupDto { Name = g.Name, Description = g.Description };
        _selectedWidgetIds = g.WidgetIds.ToHashSet();
        _formIsActive = g.IsActive;
        _showForm = true;
    }

    void CancelForm() { _showForm = false; _editingId = null; }

    async Task Save()
    {
        _saving = true;
        try
        {
            _form.WidgetIds = _selectedWidgetIds.ToList();
            if (_editingId == null)
            {
                var result = await ApiService.CreateWidgetGroupAsync(_form);
                Snackbar.Add(result != null ? "Đã tạo nhóm!" : "Tạo nhóm thất bại.", result != null ? Severity.Success : Severity.Error);
            }
            else
            {
                var updateDto = new UpdateWidgetGroupDto
                {
                    Name = _form.Name, Description = _form.Description,
                    WidgetIds = _form.WidgetIds, IsActive = _formIsActive
                };
                var result = await ApiService.UpdateWidgetGroupAsync(_editingId.Value, updateDto);
                Snackbar.Add(result != null ? "Đã cập nhật nhóm!" : "Cập nhật thất bại.", result != null ? Severity.Success : Severity.Error);
            }
            _showForm = false;
            _editingId = null;
            await LoadGroupsAsync();
        }
        finally { _saving = false; }
    }

    async Task DoDelete()
    {
        if (_deletingItem == null) return;
        var result = await ApiService.DeleteWidgetGroupAsync(_deletingItem.Id);
        Snackbar.Add(result ? "Đã xóa nhóm!" : "Xóa thất bại.", result ? Severity.Success : Severity.Error);
        _deletingItem = null;
        await LoadGroupsAsync();
    }
}
