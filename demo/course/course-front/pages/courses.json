      "template": "<div class=\"we-section\" style=\"background:#f7fafc\"><h2 class=\"we-section-title\" style=\"margin-bottom:6px\">{{title}}</h2><p class=\"we-section-subtitle\" style=\"margin-bottom:20px\">{{subtitle}}</p><div class=\"we-products\">{{#each rows}}<div class=\"we-product-card\"><div class=\"we-product-img\" style=\"font-size:44px;display:flex;align-items:center;justify-content:center;height:100px;background:linear-gradient(135deg,#f0fff4,#c6f6d5);border-radius:10px 10px 0 0\">{{icon}}</div><div class=\"we-product-body\"><div style=\"font-size:11px;color:#38a169;font-weight:700;margin-bottom:4px\">{{level}} · {{duration}}</div>{{#if badge}}<span class=\"we-product-badge\" style=\"background:#38a169;color:#fff\">{{badge}}</span>{{/if}}<h3 class=\"we-product-name\" style=\"font-size:13px;margin:5px 0 4px;line-height:1.4\">{{name}}</h3><div style=\"font-size:11px;color:#718096;margin-bottom:3px\">👨‍🏫 {{instructor}}</div><div style=\"font-size:11px;color:#718096;margin-bottom:6px\">⭐ {{rating}} · {{students}} học viên</div><div style=\"display:flex;align-items:baseline;gap:6px;margin-bottom:8px\"><span style=\"color:#38a169;font-weight:700;font-size:15px\">{{price}}</span>{{#if old_price}}<span style=\"font-size:11px;color:#a0aec0;text-decoration:line-through\">{{old_price}}</span>{{/if}}</div><a class=\"we-btn we-btn-primary\" href=\"{{href}}\" style=\"background:#38a169;color:#fff;border-color:#38a169;display:block;text-align:center;font-size:12px\">🎓 Đăng ký học</a></div></div>{{/each}}</div></div>"
