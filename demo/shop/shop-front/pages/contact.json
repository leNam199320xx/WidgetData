{
  "title": "Liên hệ – WidgetData",
  "layout": "flex",
  "auth": { "required": false },
  "widgets": [
    {
      "staticData": {
        "headline": "Liên hệ với chúng tôi",
        "subheadline": "Có câu hỏi về WidgetData? Gửi tin nhắn và đội ngũ sẽ phản hồi trong vòng 24 giờ."
      },
      "template": "<div class=\"we-hero\" style=\"padding:56px 24px 48px\"><h1 class=\"we-hero-headline\">{{headline}}</h1><p class=\"we-hero-subheadline\">{{subheadline}}</p></div>"
    },
    {
      "staticData": {
        "rows": [
          { "icon": "📧", "label": "Email hỗ trợ",      "value": "support@widgetdata.com" },
          { "icon": "💬", "label": "Zalo / Telegram",   "value": "@widgetdata" },
          { "icon": "🕐", "label": "Giờ làm việc",       "value": "T2–T6, 8:00–17:30" },
          { "icon": "📍", "label": "Văn phòng",          "value": "Hà Nội, Việt Nam" }
        ]
      },
      "template": "<div class=\"we-section\"><h2 class=\"we-section-title\" style=\"text-align:center;margin-bottom:32px\">Thông tin liên hệ</h2><div style=\"display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:20px;max-width:800px;margin:0 auto\">{{#each rows}}<div style=\"background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:20px 24px;display:flex;align-items:flex-start;gap:12px\"><span style=\"font-size:28px\">{{icon}}</span><div><div style=\"font-size:12px;font-weight:700;color:#718096;text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px\">{{label}}</div><div style=\"font-size:15px;font-weight:600;color:#1a202c\">{{value}}</div></div></div>{{/each}}</div></div>"
    },
    {
      "formId": 1,
      "title": "Gửi tin nhắn"
    },
    {
      "staticData": {
        "title": "Form Widget — Tích hợp dễ dàng",
        "desc": "Widget trên được render tự động từ schema định nghĩa trong WidgetData Admin. Thêm, sửa, xoá trường — không cần chỉnh code frontend.",
        "endpoint_schema": "GET /api/form/{id}/schema",
        "endpoint_submit": "POST /api/form/{id}",
        "endpoint_submissions": "GET /api/form/{id}/submissions  (Admin)"
      },
      "template": "<div class=\"we-section\" style=\"background:#f7fafc;padding:40px 24px\"><div style=\"max-width:680px;margin:0 auto;text-align:center\"><h3 style=\"font-size:18px;font-weight:700;color:#1a202c;margin:0 0 10px\">{{title}}</h3><p style=\"font-size:14px;color:#718096;margin:0 0 20px;line-height:1.6\">{{desc}}</p><div style=\"display:flex;flex-direction:column;gap:8px;text-align:left;background:#fff;border:1px solid #e2e8f0;border-radius:8px;padding:16px 20px\"><code style=\"font-size:13px;color:#2b6cb0\">{{endpoint_schema}}</code><code style=\"font-size:13px;color:#2b6cb0\">{{endpoint_submit}}</code><code style=\"font-size:13px;color:#718096\">{{endpoint_submissions}}</code></div></div></div>"
    }
  ]
}
