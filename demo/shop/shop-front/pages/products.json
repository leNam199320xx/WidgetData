{
  "title": "Sản phẩm – WidgetData",
  "layout": "flex",
  "auth": { "required": false },
  "widgets": [
    {
      "staticData": {
        "headline": "Chọn gói phù hợp với bạn",
        "subheadline": "Tất cả gói đều bao gồm 14 ngày dùng thử miễn phí và hỗ trợ kỹ thuật 24/7."
      },
      "template": "<div class=\"we-hero\" style=\"padding:56px 24px 48px\"><h1 class=\"we-hero-headline\">{{headline}}</h1><p class=\"we-hero-subheadline\">{{subheadline}}</p></div>"
    },
    {
      "staticData": {
        "rows": [
          {
            "name": "Starter",
            "price": "Miễn phí",
            "period": "mãi mãi",
            "featured": "",
            "badge": "",
            "f1": "5 widget",
            "f2": "1 nguồn dữ liệu",
            "f3": "10.000 lượt xem / tháng",
            "f4": "Hỗ trợ cộng đồng",
            "cta": "Bắt đầu miễn phí"
          },
          {
            "name": "Pro",
            "price": "499.000₫",
            "period": "/ tháng",
            "featured": "we-featured",
            "badge": "<span class=\"we-pricing-badge\">Phổ biến nhất</span>",
            "f1": "Không giới hạn widget",
            "f2": "5 nguồn dữ liệu",
            "f3": "500.000 lượt xem / tháng",
            "f4": "Hỗ trợ email ưu tiên",
            "cta": "Dùng thử 14 ngày"
          },
          {
            "name": "Business",
            "price": "1.499.000₫",
            "period": "/ tháng",
            "featured": "",
            "badge": "",
            "f1": "Không giới hạn widget",
            "f2": "Không giới hạn nguồn dữ liệu",
            "f3": "Không giới hạn lượt xem",
            "f4": "Hỗ trợ riêng (SLA 4h)",
            "cta": "Liên hệ tư vấn"
          }
        ]
      },
      "template": "<div class=\"we-section we-section-center\"><h2 class=\"we-section-title\">Bảng giá dịch vụ</h2><div class=\"we-pricing\">{{#each rows}}<div class=\"we-pricing-card {{featured}}\">{{{badge}}}<div class=\"we-pricing-name\">{{name}}</div><div class=\"we-pricing-price\">{{price}}</div><div class=\"we-pricing-period\">{{period}}</div><ul class=\"we-pricing-features\"><li>{{f1}}</li><li>{{f2}}</li><li>{{f3}}</li><li>{{f4}}</li></ul><a class=\"we-btn we-btn-primary\" href=\"#\" style=\"background:#4299e1;color:#fff;border-color:#4299e1;display:block\">{{cta}}</a></div>{{/each}}</div></div>"
    },
    {
      "staticData": {
        "rows": [
          { "emoji": "📊", "name": "Widget Biểu đồ",     "desc": "Cột, đường, tròn, vùng — hỗ trợ Chart.js và D3.js.",              "badge": "Mới",  "price": "Có trong mọi gói" },
          { "emoji": "📋", "name": "Widget Bảng dữ liệu", "desc": "Phân trang, tìm kiếm, sắp xếp — tối ưu hiệu năng với big data.",  "badge": "",     "price": "Có trong mọi gói" },
          { "emoji": "🔢", "name": "Widget Số liệu",      "desc": "Hiển thị KPI, doanh số, số đơn hàng theo thời gian thực.",        "badge": "",     "price": "Có trong mọi gói" },
          { "emoji": "🗺️", "name": "Widget Bản đồ",       "desc": "Phân tích dữ liệu theo vùng địa lý, tích hợp Google Maps.",       "badge": "Pro+", "price": "Pro & Business"   },
          { "emoji": "📅", "name": "Widget Lịch",         "desc": "Hiển thị lịch sự kiện, đơn hàng, lịch giao hàng trực quan.",      "badge": "Pro+", "price": "Pro & Business"   },
          { "emoji": "🔔", "name": "Widget Cảnh báo",     "desc": "Tự động gửi thông báo khi dữ liệu vượt ngưỡng đã đặt.",          "badge": "Pro+", "price": "Business"         }
        ]
      },
      "template": "<div class=\"we-section\"><h2 class=\"we-section-title\" style=\"text-align:center;margin-bottom:12px\">Danh mục widget</h2><p class=\"we-section-subtitle\" style=\"text-align:center\">Mọi widget đều có template HTML tuỳ biến hoàn toàn.</p><div class=\"we-products\">{{#each rows}}<div class=\"we-product-card\"><div class=\"we-product-img\">{{emoji}}</div><div class=\"we-product-body\">{{#if badge}}<span class=\"we-product-badge\">{{badge}}</span>{{/if}}<h3 class=\"we-product-name\">{{name}}</h3><p class=\"we-product-desc\">{{desc}}</p><div class=\"we-product-price\" style=\"font-size:14px;color:#718096;font-weight:600\">{{price}}</div><a class=\"we-btn we-btn-primary\" href=\"#\" style=\"background:#4299e1;color:#fff;border-color:#4299e1;display:block;text-align:center\">Xem chi tiết</a></div></div>{{/each}}</div></div>"
    },
    {
      "staticData": {
        "title": "Tích hợp trong vài phút",
        "subtitle": "Chỉ cần dán 2 dòng code vào trang HTML của bạn.",
        "cta": "Xem tài liệu hướng dẫn"
      },
      "template": "<div class=\"we-section\"><div class=\"we-cta-banner\"><h2 class=\"we-cta-title\">{{title}}</h2><p class=\"we-cta-subtitle\">{{subtitle}}</p><a class=\"we-btn we-btn-cta\" href=\"#\">{{cta}}</a></div></div>"
    }
  ]
}
