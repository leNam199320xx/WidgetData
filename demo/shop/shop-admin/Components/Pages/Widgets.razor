@page "/widgets"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@using MudBlazor
@using WidgetData.Application.DTOs
@using WidgetData.Domain.Enums
@inject ShopAdmin.Services.ApiService ApiService
@inject ISnackbar Snackbar
@inject NavigationManager Nav
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Widgets_Title"] - WidgetData</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">@L["Widgets_Title"]</MudText>

@* Inline Add/Edit Form *@
@if (_showForm)
{
    <MudPaper Class="pa-4 mb-4" Elevation="3">
        <MudText Typo="Typo.h6" Class="mb-3">@(_editingId == null ? L["Widgets_AddWidget"] : L["Widgets_EditWidget"])</MudText>
        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_form.Name" Label="@L["Widgets_TechnicalName"]" Required="true" Variant="Variant.Outlined"
                              HelperText="@L["Widgets_TechnicalNameHelper"]" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_form.FriendlyLabel" Label="@L["Widgets_DisplayName"]" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_form.HelpText" Label="@L["Widgets_ShortDesc"]" Variant="Variant.Outlined"
                              HelperText="@L["Widgets_ShortDescHelper"]" />
            </MudItem>
            <MudItem xs="6" sm="3">
                <MudSelect @bind-Value="_form.WidgetType" Label="@L["Widgets_WidgetType"]" Variant="Variant.Outlined">
                    @foreach (var t in Enum.GetValues<WidgetType>())
                    {
                        <MudSelectItem Value="@t">@t</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="6" sm="3">
                <MudSelect @bind-Value="_form.DataSourceId" Label="@L["Widgets_DataSource"]" Variant="Variant.Outlined">
                    @if (_dataSources != null)
                    {
                        @foreach (var ds in _dataSources)
                        {
                            <MudSelectItem Value="@ds.Id">@ds.Name</MudSelectItem>
                        }
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_form.Description" Label="@L["Description"]" Variant="Variant.Outlined" Lines="2" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_form.Configuration" Label="@L["Widgets_ConfigJson"]" Variant="Variant.Outlined" Lines="3"
                              Placeholder='{"query": "SELECT * FROM table"}' />
            </MudItem>
            @if (_form.WidgetType == WidgetType.Chart)
            {
                <MudItem xs="12">
                    <MudTextField @bind-Value="_form.ChartConfig" Label="@L["Widgets_ChartConfigJson"]" Variant="Variant.Outlined" Lines="3"
                                  Placeholder='{"type": "line", "xAxis": "month", "yAxis": "value"}' />
                </MudItem>
            }
            <MudItem xs="6" sm="3">
                <MudCheckBox @bind-Value="_form.CacheEnabled" Label="@L["Widgets_CacheEnabled"]" Color="Color.Primary" />
            </MudItem>
            <MudItem xs="6" sm="3">
                <MudNumericField @bind-Value="_form.CacheTtlMinutes" Label="@L["Widgets_CacheTtl"]" Variant="Variant.Outlined" Min="1" Max="1440" />
            </MudItem>
            @if (_editingId != null)
            {
                <MudItem xs="6" sm="3">
                    <MudCheckBox @bind-Value="_formIsActive" Label="@L["Widgets_ActiveLabel"]" Color="Color.Primary" />
                </MudItem>
            }
            <MudItem xs="12">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveWidget" Disabled="_saving" Class="mr-2">
                    @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                    @L["Save"]
                </MudButton>
                <MudButton Variant="Variant.Outlined" OnClick="CancelForm">@L["Cancel"]</MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>
}

@* Delete confirmation *@
@if (_deletingItem != null)
{
    <MudPaper Class="pa-4 mb-4" Elevation="3" Style="border-left: 4px solid #f44336">
        <MudText Typo="Typo.h6" Color="Color.Error">@L["ConfirmDelete"]</MudText>
        <MudText Class="mb-3">@L["Widgets_DeleteConfirm", _deletingItem.Name]</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="DoDelete" Class="mr-2">@L["Delete"]</MudButton>
        <MudButton Variant="Variant.Outlined" OnClick="() => _deletingItem = null">@L["Cancel"]</MudButton>
    </MudPaper>
}

@if (_widgets != null)
{
    <MudTable Items="_widgets" Dense="true" Hover="true" Striped="true">
        <ToolBarContent>
            <MudText Typo="Typo.h6">@L["Widgets_List"]</MudText>
            <MudSpacer />
            @if (!_showForm)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                           OnClick="OpenAddForm">@L["Widgets_AddWidget"]</MudButton>
            }
        </ToolBarContent>
        <HeaderContent>
            <MudTh>@L["Name"]</MudTh>
            <MudTh>@L["Type"]</MudTh>
            <MudTh>@L["Widgets_DataSource"]</MudTh>
            <MudTh>@L["Status"]</MudTh>
            <MudTh>@L["Widgets_LastExecuted"]</MudTh>
            <MudTh>@L["Widgets_Rows"]</MudTh>
            <MudTh>@L["Actions"]</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                @(context.FriendlyLabel ?? context.Name)
                @if (!string.IsNullOrEmpty(context.HelpText))
                {
                    <MudTooltip Text="@context.HelpText">
                        <MudIcon Icon="@Icons.Material.Filled.HelpOutline" Size="Size.Small" Color="Color.Secondary" Class="ml-1" />
                    </MudTooltip>
                }
            </MudTd>
            <MudTd>@context.WidgetType</MudTd>
            <MudTd>@context.DataSourceName</MudTd>
            <MudTd><MudChip T="string" Color="@(context.IsActive ? Color.Success : Color.Error)" Size="Size.Small">@(context.IsActive ? L["Active"] : L["Inactive"])</MudChip></MudTd>
            <MudTd>@(context.LastExecutedAt.HasValue ? context.LastExecutedAt.Value.ToString("g") : L["Never"].Value)</MudTd>
            <MudTd>@(context.LastRowCount.HasValue ? context.LastRowCount.ToString() : "-")</MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.PlayArrow" Color="Color.Success" Size="Size.Small"
                               OnClick="() => ExecuteWidget(context)" Title="Chạy ngay" />
                <MudIconButton Icon="@Icons.Material.Filled.History" Color="Color.Info" Size="Size.Small"
                               OnClick="() => ViewHistory(context)" Title="Lịch sử" />
                <MudIconButton Icon="@Icons.Material.Filled.Code" Color="Color.Info" Size="Size.Small"
                               OnClick="@(() => Nav.NavigateTo($"/widgets/html-designer/{context.Id}"))" Title="HTML Designer" />
                <MudIconButton Icon="@Icons.Material.Filled.Tune" Color="Color.Secondary" Size="Size.Small"
                               OnClick="@(() => Nav.NavigateTo($"/widgets/configure/{context.Id}"))" Title="Cấu hình chi tiết" />
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Warning" Size="Size.Small"
                               OnClick="() => OpenEditForm(context)" Title="Sửa nhanh" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                               OnClick="() => _deletingItem = context" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}
else if (_error != null)
{
    <MudAlert Severity="Severity.Error">@_error</MudAlert>
}
else
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
}

@* Execution History *@
@if (_historyWidget != null)
{
    <MudText Typo="Typo.h6" Class="mt-6 mb-2">
        @L["Widgets_ExecHistory"] – @_historyWidget.Name
        <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small" OnClick="() => _historyWidget = null" />
    </MudText>
    @if (_history != null)
    {
        <MudTable Items="_history" Dense="true" Hover="true">
            <HeaderContent>
                <MudTh>@L["Status"]</MudTh>
                <MudTh>@L["Widgets_Trigger"]</MudTh>
                <MudTh>@L["Home_ColStarted"]</MudTh>
                <MudTh>@L["Home_ColDuration"]</MudTh>
                <MudTh>@L["Widgets_Rows"]</MudTh>
                <MudTh>@L["Widgets_ErrMsg"]</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd><MudChip T="string" Color="@StatusColor(context.Status)" Size="Size.Small">@context.Status</MudChip></MudTd>
                <MudTd>@context.TriggeredBy</MudTd>
                <MudTd>@context.StartedAt.ToString("g")</MudTd>
                <MudTd>@(context.ExecutionTimeMs.HasValue ? $"{context.ExecutionTimeMs}ms" : "-")</MudTd>
                <MudTd>@(context.RowCount.HasValue ? context.RowCount.ToString() : "-")</MudTd>
                <MudTd>@(context.ErrorMessage ?? "-")</MudTd>
            </RowTemplate>
        </MudTable>
    }
    else
    {
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    }
}

@code {
    IEnumerable<WidgetDto>? _widgets;
    IEnumerable<DataSourceDto>? _dataSources;
    IEnumerable<WidgetExecutionDto>? _history;
    WidgetDto? _historyWidget;
    WidgetDto? _deletingItem;
    string? _error;
    bool _showForm;
    bool _saving;
    int? _editingId;
    bool _formIsActive = true;
    CreateWidgetDto _form = new();

    protected override async Task OnInitializedAsync() => await LoadAsync();

    async Task LoadAsync()
    {
        try
        {
            _widgets = await ApiService.GetWidgetsAsync() ?? Array.Empty<WidgetDto>();
            _dataSources = await ApiService.GetDataSourcesAsync() ?? Array.Empty<DataSourceDto>();
        }
        catch (Exception ex) { _error = L["FailedToLoad", ex.Message].Value; _widgets = Array.Empty<WidgetDto>(); }
    }

    void OpenAddForm()
    {
        _editingId = null;
        _form = new CreateWidgetDto { WidgetType = WidgetType.Table, CacheTtlMinutes = 15 };
        _formIsActive = true;
        _showForm = true;
    }

    void OpenEditForm(WidgetDto w)
    {
        _editingId = w.Id;
        _form = new CreateWidgetDto
        {
            Name = w.Name, FriendlyLabel = w.FriendlyLabel, HelpText = w.HelpText,
            WidgetType = w.WidgetType, Description = w.Description,
            DataSourceId = w.DataSourceId, Configuration = w.Configuration,
            ChartConfig = w.ChartConfig, CacheEnabled = w.CacheEnabled, CacheTtlMinutes = w.CacheTtlMinutes
        };
        _formIsActive = w.IsActive;
        _showForm = true;
    }

    void CancelForm() { _showForm = false; _editingId = null; }

    async Task SaveWidget()
    {
        _saving = true;
        try
        {
            if (_editingId == null)
            {
                var result = await ApiService.CreateWidgetAsync(_form);
                Snackbar.Add(result != null ? L["Widgets_Created"].Value : L["FailedCreate"].Value, result != null ? Severity.Success : Severity.Error);
            }
            else
            {
                var dto = new UpdateWidgetDto
                {
                    Name = _form.Name, WidgetType = _form.WidgetType, Description = _form.Description,
                    DataSourceId = _form.DataSourceId, Configuration = _form.Configuration,
                    ChartConfig = _form.ChartConfig, CacheEnabled = _form.CacheEnabled,
                    CacheTtlMinutes = _form.CacheTtlMinutes, IsActive = _formIsActive
                };
                var result = await ApiService.UpdateWidgetAsync(_editingId.Value, dto);
                Snackbar.Add(result != null ? L["Widgets_Updated"].Value : L["FailedUpdate"].Value, result != null ? Severity.Success : Severity.Error);
            }
            _showForm = false;
            await LoadAsync();
        }
        finally { _saving = false; }
    }

    async Task ExecuteWidget(WidgetDto w)
    {
        var result = await ApiService.ExecuteWidgetAsync(w.Id);
        if (result != null)
            Snackbar.Add(L["Widgets_ExecResult", w.Name, result.Status, result.ExecutionTimeMs, result.RowCount].Value, Severity.Success);
        else
            Snackbar.Add(L["Widgets_ExecFailed"].Value, Severity.Error);
        await LoadAsync();
    }

    async Task ViewHistory(WidgetDto w)
    {
        _historyWidget = w;
        _history = null;
        _history = await ApiService.GetWidgetHistoryAsync(w.Id) ?? Array.Empty<WidgetExecutionDto>();
    }

    async Task DoDelete()
    {
        if (_deletingItem == null) return;
        var ok = await ApiService.DeleteWidgetAsync(_deletingItem.Id);
        Snackbar.Add(ok ? L["Deleted"].Value : L["DeleteFailed"].Value, ok ? Severity.Success : Severity.Error);
        _deletingItem = null;
        await LoadAsync();
    }

    static Color StatusColor(ExecutionStatus s) => s switch
    {
        ExecutionStatus.Success => Color.Success,
        ExecutionStatus.Running => Color.Info,
        ExecutionStatus.Failed => Color.Error,
        _ => Color.Default
    };
}
