@page "/store/products"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@layout StoreLayout

<PageTitle>Quản lý sản phẩm - WidgetData</PageTitle>

<StorePageHeader Title="Quản lý sản phẩm" Icon="@Icons.Material.Filled.Inventory2" />

@* Add/Edit Form *@
@if (_showForm)
{
    <MudPaper Class="pa-4 mb-4" Elevation="3">
        <MudText Typo="Typo.h6" Class="mb-3">@(_editingId == null ? "➕ Thêm sản phẩm mới" : "✏️ Chỉnh sửa sản phẩm")</MudText>
        <MudGrid>
            <MudItem xs="12" sm="6">
                <MudTextField @bind-Value="_form.Name" Label="Tên sản phẩm" Required="true" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudSelect @bind-Value="_form.Category" Label="Danh mục" Variant="Variant.Outlined">
                    @foreach (var cat in _categories)
                    {
                        <MudSelectItem Value="@cat">@cat</MudSelectItem>
                    }
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudNumericField @bind-Value="_form.Price" Label="Giá bán (₫)" Variant="Variant.Outlined" Min="0" Format="N0" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudNumericField @bind-Value="_form.CostPrice" Label="Giá nhập (₫)" Variant="Variant.Outlined" Min="0" Format="N0" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudNumericField @bind-Value="_form.Stock" Label="Tồn kho" Variant="Variant.Outlined" Min="0" />
            </MudItem>
            <MudItem xs="12" sm="8">
                <MudTextField @bind-Value="_form.Description" Label="Mô tả" Variant="Variant.Outlined" Lines="2" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudTextField @bind-Value="_form.Sku" Label="Mã SKU" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveProduct" Class="mr-2">Lưu</MudButton>
                <MudButton Variant="Variant.Outlined" OnClick="() => _showForm = false">Hủy</MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>
}

@* Delete confirm *@
@if (_deletingItem != null)
{
    <StoreDeleteConfirm Message="@($"Bạn có chắc muốn xóa sản phẩm {_deletingItem.Name}?")"
                        OnConfirm="DoDelete" OnCancel="@(() => _deletingItem = null)" />
}

@* Filter Bar *@
<MudPaper Class="pa-3 mb-4" Elevation="1">
    <MudGrid AlignItems="AlignItems.Center">
        <MudItem xs="12" sm="5">
            <MudTextField @bind-Value="_search" Label="Tìm kiếm sản phẩm..." Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search" Variant="Variant.Outlined"
                          Immediate="true" Clearable="true" Margin="Margin.Dense" />
        </MudItem>
        <MudItem xs="12" sm="3">
            <MudSelect @bind-Value="_filterCategory" Label="Danh mục" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                @foreach (var cat in _categories)
                {
                    <MudSelectItem Value="@cat">@cat</MudSelectItem>
                }
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="2">
            <MudSelect @bind-Value="_filterStatus" Label="Trạng thái" Variant="Variant.Outlined" Margin="Margin.Dense" Clearable="true">
                <MudSelectItem Value="@("Đang bán")">Đang bán</MudSelectItem>
                <MudSelectItem Value="@("Hết hàng")">Hết hàng</MudSelectItem>
                <MudSelectItem Value="@("Ngừng bán")">Ngừng bán</MudSelectItem>
            </MudSelect>
        </MudItem>
        <MudItem xs="12" sm="2" Class="d-flex justify-end">
            @if (!_showForm)
            {
                <MudButton Variant="Variant.Filled" Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add" OnClick="OpenAddForm">
                    Thêm sản phẩm
                </MudButton>
            }
        </MudItem>
    </MudGrid>
</MudPaper>

@* Product Table *@
<MudTable Items="FilteredProducts" Dense="true" Hover="true" Striped="true" Elevation="2">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Danh sách sản phẩm</MudText>
        <MudSpacer />
        <MudChip T="string" Color="Color.Default" Size="Size.Small">@FilteredProducts.Count() sản phẩm</MudChip>
    </ToolBarContent>
    <HeaderContent>
        <MudTh>SKU</MudTh>
        <MudTh>Tên sản phẩm</MudTh>
        <MudTh>Danh mục</MudTh>
        <MudTh>Giá bán</MudTh>
        <MudTh>Giá nhập</MudTh>
        <MudTh>Tồn kho</MudTh>
        <MudTh>Trạng thái</MudTh>
        <MudTh>Thao tác</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd><MudText Typo="Typo.caption" Color="Color.Secondary">@context.Sku</MudText></MudTd>
        <MudTd>
            <div>
                <MudText Typo="Typo.body2"><strong>@context.Name</strong></MudText>
                <MudText Typo="Typo.caption" Color="Color.Secondary">@context.Description</MudText>
            </div>
        </MudTd>
        <MudTd><MudChip T="string" Size="Size.Small" Color="Color.Default">@context.Category</MudChip></MudTd>
        <MudTd><MudText Color="Color.Primary">₫ @context.Price.ToString("N0")</MudText></MudTd>
        <MudTd><MudText Color="Color.Secondary">₫ @context.CostPrice.ToString("N0")</MudText></MudTd>
        <MudTd>
            @if (context.Stock == 0)
            {
                <MudChip T="string" Color="Color.Error" Size="Size.Small">Hết hàng</MudChip>
            }
            else if (context.Stock < 10)
            {
                <MudChip T="string" Color="Color.Warning" Size="Size.Small">@context.Stock (thấp)</MudChip>
            }
            else
            {
                <MudText>@context.Stock</MudText>
            }
        </MudTd>
        <MudTd>
            <MudChip T="string" Color="@GetProductStatusColor(context.Status)" Size="Size.Small">@context.Status</MudChip>
        </MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Warning" Size="Size.Small"
                           OnClick="() => OpenEditForm(context)" Title="Chỉnh sửa" />
            <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                           OnClick="() => _deletingItem = context" Title="Xóa" />
        </MudTd>
    </RowTemplate>
</MudTable>

@code {
    class ProductModel
    {
        public int Id { get; set; }
        public string Sku { get; set; } = "";
        public string Name { get; set; } = "";
        public string Category { get; set; } = "";
        public decimal Price { get; set; }
        public decimal CostPrice { get; set; }
        public int Stock { get; set; }
        public string Description { get; set; } = "";
        public string Status { get; set; } = "Đang bán";
    }

    class ProductForm
    {
        public string Name { get; set; } = "";
        public string Category { get; set; } = "Thời trang nam";
        public decimal Price { get; set; }
        public decimal CostPrice { get; set; }
        public int Stock { get; set; }
        public string Description { get; set; } = "";
        public string Sku { get; set; } = "";
    }

    readonly string[] _categories = ["Thời trang nam", "Thời trang nữ", "Giày dép", "Túi xách", "Phụ kiện", "Đồ gia dụng"];

    List<ProductModel> _products =
    [
        new() { Id = 1, Sku = "ATN-001", Name = "Áo thun nam Premium", Category = "Thời trang nam", Price = 280000, CostPrice = 150000, Stock = 142, Description = "Chất liệu cotton 100%", Status = "Đang bán" },
        new() { Id = 2, Sku = "QJN-001", Name = "Quần jean slim fit", Category = "Thời trang nam", Price = 450000, CostPrice = 220000, Stock = 88, Description = "Denim cao cấp, form slim", Status = "Đang bán" },
        new() { Id = 3, Sku = "GSN-001", Name = "Giày sneaker trắng", Category = "Giày dép", Price = 650000, CostPrice = 320000, Stock = 45, Description = "Da PU cao cấp, đế EVA", Status = "Đang bán" },
        new() { Id = 4, Sku = "TXN-001", Name = "Túi xách nữ da PU", Category = "Túi xách", Price = 380000, CostPrice = 180000, Stock = 5, Description = "Da PU mềm, nhiều ngăn", Status = "Đang bán" },
        new() { Id = 5, Sku = "NLT-001", Name = "Nón lưỡi trai thời trang", Category = "Phụ kiện", Price = 120000, CostPrice = 55000, Stock = 200, Description = "Chất liệu canvas", Status = "Đang bán" },
        new() { Id = 6, Sku = "ATN-002", Name = "Áo sơ mi nam công sở", Category = "Thời trang nam", Price = 350000, CostPrice = 170000, Stock = 0, Description = "Cotton pha polyester", Status = "Hết hàng" },
        new() { Id = 7, Sku = "VDN-001", Name = "Váy đầm nữ hoa nhí", Category = "Thời trang nữ", Price = 420000, CostPrice = 200000, Stock = 67, Description = "Voan mềm, thoáng mát", Status = "Đang bán" },
        new() { Id = 8, Sku = "DAG-001", Name = "Dép sandal nữ quai hậu", Category = "Giày dép", Price = 180000, CostPrice = 80000, Stock = 3, Description = "Đế cao 3cm", Status = "Đang bán" },
        new() { Id = 9, Sku = "KTN-001", Name = "Kính mắt thời trang UV400", Category = "Phụ kiện", Price = 95000, CostPrice = 40000, Stock = 150, Description = "Chống UV400", Status = "Đang bán" },
        new() { Id = 10, Sku = "ATN-003", Name = "Áo khoác jean unisex", Category = "Thời trang nam", Price = 520000, CostPrice = 250000, Stock = 0, Description = "Denim wash, form rộng", Status = "Ngừng bán" },
    ];

    bool _showForm;
    int? _editingId;
    ProductModel? _deletingItem;
    ProductForm _form = new();
    string _search = "";
    string? _filterCategory;
    string? _filterStatus;
    int _nextId = 11;

    IEnumerable<ProductModel> FilteredProducts => _products
        .Where(p => string.IsNullOrEmpty(_search) || p.Name.Contains(_search, StringComparison.OrdinalIgnoreCase) || p.Sku.Contains(_search, StringComparison.OrdinalIgnoreCase))
        .Where(p => string.IsNullOrEmpty(_filterCategory) || p.Category == _filterCategory)
        .Where(p => string.IsNullOrEmpty(_filterStatus) || p.Status == _filterStatus);

    void OpenAddForm()
    {
        _editingId = null;
        _form = new ProductForm();
        _showForm = true;
    }

    void OpenEditForm(ProductModel p)
    {
        _editingId = p.Id;
        _form = new ProductForm { Name = p.Name, Category = p.Category, Price = p.Price, CostPrice = p.CostPrice, Stock = p.Stock, Description = p.Description, Sku = p.Sku };
        _showForm = true;
    }

    void SaveProduct()
    {
        if (_editingId == null)
        {
            _products.Add(new ProductModel
            {
                Id = _nextId++, Sku = _form.Sku, Name = _form.Name, Category = _form.Category,
                Price = _form.Price, CostPrice = _form.CostPrice, Stock = _form.Stock,
                Description = _form.Description, Status = _form.Stock > 0 ? "Đang bán" : "Hết hàng"
            });
        }
        else
        {
            var existing = _products.First(p => p.Id == _editingId);
            existing.Name = _form.Name; existing.Category = _form.Category;
            existing.Price = _form.Price; existing.CostPrice = _form.CostPrice;
            existing.Stock = _form.Stock; existing.Description = _form.Description;
            existing.Sku = _form.Sku;
            existing.Status = _form.Stock > 0 ? "Đang bán" : "Hết hàng";
        }
        _showForm = false;
    }

    void DoDelete()
    {
        if (_deletingItem != null) { _products.Remove(_deletingItem); _deletingItem = null; }
    }

    static Color GetProductStatusColor(string status) => status switch
    {
        "Đang bán" => Color.Success,
        "Hết hàng" => Color.Error,
        "Ngừng bán" => Color.Default,
        _ => Color.Default
    };
}
