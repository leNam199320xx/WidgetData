@page "/store"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@layout StoreLayout

<PageTitle>Tổng quan cửa hàng - WidgetData</PageTitle>

<StorePageHeader Title="Tổng quan cửa hàng" Icon="@Icons.Material.Filled.Store"
                 Subtitle="@($"Cập nhật lần cuối: {DateTime.Now:dd/MM/yyyy HH:mm}")" />

@* KPI Cards *@
<MudGrid Class="mb-4">
    <MudItem xs="12" sm="6" md="3">
        <StoreKpiCard Value="₫ 24,580,000" Label="Doanh thu hôm nay" Trend="▲ 12.5% so với hôm qua"
                      Icon="@Icons.Material.Filled.AttachMoney" ValueColor="Color.Success" BorderColor="#4caf50" />
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <StoreKpiCard Value="47" Label="Đơn hàng hôm nay" Trend="▲ 8 đơn so với hôm qua"
                      Icon="@Icons.Material.Filled.ShoppingCart" ValueColor="Color.Primary" BorderColor="#2196f3" />
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <StoreKpiCard Value="15" Label="Khách hàng mới" Trend="▲ 3 so với hôm qua"
                      Icon="@Icons.Material.Filled.PersonAdd" ValueColor="Color.Warning" BorderColor="#ff9800" />
    </MudItem>
    <MudItem xs="12" sm="6" md="3">
        <StoreKpiCard Value="8" Label="Sản phẩm sắp hết" Trend="Cần nhập thêm hàng"
                      Icon="@Icons.Material.Filled.Warning" ValueColor="Color.Error" BorderColor="#f44336" />
    </MudItem>
</MudGrid>

@* Revenue Chart + Order Status *@
<MudGrid Class="mb-4">
    <MudItem xs="12" md="8">
        <MudCard Elevation="2">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">
                        <MudIcon Icon="@Icons.Material.Filled.BarChart" Class="mr-1" />
                        Doanh thu 7 ngày gần đây
                    </MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudChip T="string" Color="Color.Primary" Size="Size.Small">Tuần này</MudChip>
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent>
                <MudChart T="double" ChartType="ChartType.Bar"
                          ChartSeries="@_revenueSeries"
                          XAxisLabels="@_revenueLabels"
                          Width="100%" Height="250px"
                          ChartOptions="@_chartOptions" />
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12" md="4">
        <MudCard Elevation="2" Style="height: 100%">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">
                        <MudIcon Icon="@Icons.Material.Filled.DonutLarge" Class="mr-1" />
                        Trạng thái đơn hàng
                    </MudText>
                </CardHeaderContent>
            </MudCardHeader>
            <MudCardContent>
                <MudChart T="double" ChartType="ChartType.Donut"
                          InputData="@_orderStatusData"
                          InputLabels="@_orderStatusLabels"
                          Width="100%" Height="200px" />
                <div class="mt-2">
                    @for (int i = 0; i < _orderStatusLabels.Length; i++)
                    {
                        var idx = i;
                        <div class="d-flex justify-space-between mb-1">
                            <MudText Typo="Typo.body2">@_orderStatusLabels[idx]</MudText>
                            <MudText Typo="Typo.body2"><strong>@((int)_orderStatusData[idx])</strong></MudText>
                        </div>
                    }
                </div>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@* Recent Orders + Top Products *@
<MudGrid>
    <MudItem xs="12" md="7">
        <MudCard Elevation="2">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">
                        <MudIcon Icon="@Icons.Material.Filled.Receipt" Class="mr-1" />
                        Đơn hàng gần đây
                    </MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/store/orders" Size="Size.Small">Xem tất cả</MudButton>
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent Class="pa-0">
                <MudTable Items="_recentOrders" Dense="true" Hover="true" Elevation="0">
                    <HeaderContent>
                        <MudTh>Mã đơn</MudTh>
                        <MudTh>Khách hàng</MudTh>
                        <MudTh>Tổng tiền</MudTh>
                        <MudTh>Trạng thái</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd><MudLink Href="/store/orders">@context.Id</MudLink></MudTd>
                        <MudTd>@context.Customer</MudTd>
                        <MudTd>₫ @context.Total.ToString("N0")</MudTd>
                        <MudTd>
                            <MudChip T="string" Color="@GetOrderStatusColor(context.Status)" Size="Size.Small">@context.Status</MudChip>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12" md="5">
        <MudCard Elevation="2">
            <MudCardHeader>
                <CardHeaderContent>
                    <MudText Typo="Typo.h6">
                        <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Class="mr-1" />
                        Sản phẩm bán chạy
                    </MudText>
                </CardHeaderContent>
                <CardHeaderActions>
                    <MudButton Variant="Variant.Text" Color="Color.Primary" Href="/store/products" Size="Size.Small">Xem tất cả</MudButton>
                </CardHeaderActions>
            </MudCardHeader>
            <MudCardContent>
                @foreach (var p in _topProducts)
                {
                    <div class="mb-3">
                        <div class="d-flex justify-space-between mb-1">
                            <MudText Typo="Typo.body2">@p.Name</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Primary"><strong>@p.Sold đơn</strong></MudText>
                        </div>
                        <MudProgressLinear Color="Color.Primary" Value="@(p.Sold * 100.0 / 150)" Rounded="true" Size="Size.Small" />
                    </div>
                }
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    record RecentOrder(string Id, string Customer, decimal Total, string Status);
    record TopProduct(string Name, int Sold);

    readonly List<RecentOrder> _recentOrders =
    [
        new("#DH2025001", "Nguyễn Văn An", 850000, "Hoàn thành"),
        new("#DH2025002", "Trần Thị Bình", 1200000, "Đang giao"),
        new("#DH2025003", "Lê Minh Cường", 450000, "Chờ xử lý"),
        new("#DH2025004", "Phạm Thu Dung", 2350000, "Hoàn thành"),
        new("#DH2025005", "Hoàng Văn Em", 750000, "Đang giao"),
        new("#DH2025006", "Vũ Thị Fang", 980000, "Đã hủy"),
    ];

    readonly List<TopProduct> _topProducts =
    [
        new("Áo thun nam Premium", 142),
        new("Quần jean slim fit", 118),
        new("Giày sneaker trắng", 95),
        new("Túi xách nữ da PU", 87),
        new("Nón lưỡi trai thời trang", 73),
    ];

    readonly string[] _revenueLabels = ["10/4", "11/4", "12/4", "13/4", "14/4", "15/4", "Hôm nay"];
    readonly List<ChartSeries<double>> _revenueSeries = new()
    {
        new ChartSeries<double>
        {
            Name = "Doanh thu (triệu ₫)",
            Data = new double[] { 18.2, 21.5, 19.8, 25.3, 22.1, 23.7, 24.6 }
        }
    };

    readonly ChartOptions _chartOptions = new();

    readonly double[] _orderStatusData = [22, 14, 8, 3];
    readonly string[] _orderStatusLabels = ["Hoàn thành", "Đang giao", "Chờ xử lý", "Đã hủy"];

    static Color GetOrderStatusColor(string status) => status switch
    {
        "Hoàn thành" => Color.Success,
        "Đang giao" => Color.Info,
        "Chờ xử lý" => Color.Warning,
        "Đã hủy" => Color.Error,
        _ => Color.Default
    };
}
