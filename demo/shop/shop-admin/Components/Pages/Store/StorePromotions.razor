@page "/store/promotions"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@layout StoreLayout

<PageTitle>Khuyến mãi - WidgetData</PageTitle>

<StorePageHeader Title="Quản lý khuyến mãi" Icon="@Icons.Material.Filled.LocalOffer" />

@* Summary *@
<MudGrid Class="mb-4">
    <MudItem xs="12" sm="4">
        <StoreKpiCard Value="@_promos.Count(p => p.Status == "Đang chạy").ToString()" Label="Khuyến mãi đang chạy"
                      ValueColor="Color.Success" BorderColor="#4caf50" />
    </MudItem>
    <MudItem xs="12" sm="4">
        <StoreKpiCard Value="@_promos.Count(p => p.Status == "Sắp diễn ra").ToString()" Label="Sắp diễn ra"
                      ValueColor="Color.Warning" BorderColor="#ff9800" />
    </MudItem>
    <MudItem xs="12" sm="4">
        <StoreKpiCard Value="@_promos.Count(p => p.Status == "Đã kết thúc").ToString()" Label="Đã kết thúc"
                      BorderColor="#9e9e9e" />
    </MudItem>
</MudGrid>

@* Add/Edit Form *@
@if (_showForm)
{
    <MudPaper Class="pa-4 mb-4" Elevation="3">
        <MudText Typo="Typo.h6" Class="mb-3">@(_editingId == null ? "➕ Tạo khuyến mãi mới" : "✏️ Chỉnh sửa khuyến mãi")</MudText>
        <MudGrid>
            <MudItem xs="12" sm="8">
                <MudTextField @bind-Value="_form.Name" Label="Tên chương trình khuyến mãi" Required="true" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudSelect @bind-Value="_form.Type" Label="Loại khuyến mãi" Variant="Variant.Outlined">
                    <MudSelectItem Value="@("Giảm %")">Giảm %</MudSelectItem>
                    <MudSelectItem Value="@("Giảm tiền")">Giảm tiền trực tiếp</MudSelectItem>
                    <MudSelectItem Value="@("Mua X tặng Y")">Mua X tặng Y</MudSelectItem>
                    <MudSelectItem Value="@("Free ship")">Miễn phí vận chuyển</MudSelectItem>
                    <MudSelectItem Value="@("Quà tặng")">Quà tặng kèm</MudSelectItem>
                </MudSelect>
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudNumericField @bind-Value="_form.DiscountValue" Label="Giá trị khuyến mãi" Variant="Variant.Outlined" Min="0" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudTextField @bind-Value="_form.Code" Label="Mã coupon (nếu có)" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12" sm="4">
                <MudNumericField @bind-Value="_form.MinOrderValue" Label="Đơn hàng tối thiểu (₫)" Variant="Variant.Outlined" Min="0" Format="N0" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudDatePicker @bind-Date="_form.StartDate" Label="Ngày bắt đầu" Variant="Variant.Outlined" DateFormat="dd/MM/yyyy" />
            </MudItem>
            <MudItem xs="12" sm="6">
                <MudDatePicker @bind-Date="_form.EndDate" Label="Ngày kết thúc" Variant="Variant.Outlined" DateFormat="dd/MM/yyyy" />
            </MudItem>
            <MudItem xs="12">
                <MudTextField @bind-Value="_form.Description" Label="Mô tả" Variant="Variant.Outlined" Lines="2" />
            </MudItem>
            <MudItem xs="12">
                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SavePromo" Class="mr-2">Lưu</MudButton>
                <MudButton Variant="Variant.Outlined" OnClick="() => _showForm = false">Hủy</MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>
}

@* Delete Confirm *@
@if (_deletingItem != null)
{
    <StoreDeleteConfirm Message="@($"Xóa chương trình {_deletingItem.Name}?")"
                        OnConfirm="DoDelete" OnCancel="@(() => _deletingItem = null)" />
}

@* Add Button *@
@if (!_showForm)
{
    <div class="mb-3 d-flex justify-end">
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add" OnClick="OpenAddForm">
            Tạo khuyến mãi
        </MudButton>
    </div>
}

@* Active Promotions *@
<MudText Typo="Typo.h6" Class="mb-2">🟢 Đang chạy</MudText>
<MudGrid Class="mb-4">
    @foreach (var p in _promos.Where(x => x.Status == "Đang chạy"))
    {
        <MudItem xs="12" sm="6" md="4">
            <MudCard Elevation="3" Style="border-top: 3px solid #4caf50">
                <MudCardHeader>
                    <CardHeaderAvatar>
                        <MudIcon Icon="@GetPromoIcon(p.Type)" Color="Color.Success" />
                    </CardHeaderAvatar>
                    <CardHeaderContent>
                        <MudText Typo="Typo.h6">@p.Name</MudText>
                        <MudChip T="string" Size="Size.Small" Color="Color.Primary">@p.Type</MudChip>
                    </CardHeaderContent>
                    <CardHeaderActions>
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Color="Color.Warning" OnClick="() => OpenEditForm(p)" />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error" OnClick="() => _deletingItem = p" />
                    </CardHeaderActions>
                </MudCardHeader>
                <MudCardContent>
                    <MudText Typo="Typo.body2" Class="mb-1">@p.Description</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Error"><strong>Giảm: @FormatDiscount(p)</strong></MudText>
                    @if (!string.IsNullOrEmpty(p.Code))
                    {
                        <MudChip T="string" Color="Color.Warning" Size="Size.Small" Icon="@Icons.Material.Filled.QrCode">@p.Code</MudChip>
                    }
                    @if (p.MinOrderValue > 0)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Đơn tối thiểu: ₫ @p.MinOrderValue.ToString("N0")</MudText>
                    }
                </MudCardContent>
                <MudCardContent Class="py-1">
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        📅 @p.StartDate?.ToString("dd/MM/yyyy") → @p.EndDate?.ToString("dd/MM/yyyy")
                    </MudText>
                    @{
                        var daysLeft = p.EndDate.HasValue ? (int)(p.EndDate.Value - DateTime.Today).TotalDays : 0;
                    }
                    <MudProgressLinear Color="@(daysLeft <= 3 ? Color.Error : Color.Success)"
                                       Value="@(p.EndDate.HasValue && p.StartDate.HasValue ? 100.0 - daysLeft * 100.0 / (p.EndDate.Value - p.StartDate.Value).TotalDays : 50)"
                                       Rounded="true" Size="Size.Small" />
                    <MudText Typo="Typo.caption" Color="@(daysLeft <= 3 ? Color.Error : Color.Secondary)">
                        Còn @daysLeft ngày
                    </MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
    }
</MudGrid>

@* Upcoming Promotions *@
@if (_promos.Any(x => x.Status == "Sắp diễn ra"))
{
    <MudText Typo="Typo.h6" Class="mb-2">🟡 Sắp diễn ra</MudText>
    <MudTable Items="UpcomingPromos" Dense="true" Hover="true" Elevation="2" Class="mb-4">
        <HeaderContent>
            <MudTh>Tên</MudTh>
            <MudTh>Loại</MudTh>
            <MudTh>Giảm giá</MudTh>
            <MudTh>Bắt đầu</MudTh>
            <MudTh>Kết thúc</MudTh>
            <MudTh>Thao tác</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Name</MudTd>
            <MudTd><MudChip T="string" Size="Size.Small">@context.Type</MudChip></MudTd>
            <MudTd>@FormatDiscount(context)</MudTd>
            <MudTd>@context.StartDate?.ToString("dd/MM/yyyy")</MudTd>
            <MudTd>@context.EndDate?.ToString("dd/MM/yyyy")</MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Warning" Size="Size.Small" OnClick="() => OpenEditForm(context)" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="() => _deletingItem = context" />
            </MudTd>
        </RowTemplate>
    </MudTable>
}

@* Ended Promotions *@
@if (_promos.Any(x => x.Status == "Đã kết thúc"))
{
    <MudText Typo="Typo.h6" Class="mb-2">⚫ Đã kết thúc</MudText>
    <MudTable Items="EndedPromos" Dense="true" Hover="true" Elevation="1">
        <HeaderContent>
            <MudTh>Tên</MudTh>
            <MudTh>Loại</MudTh>
            <MudTh>Giảm giá</MudTh>
            <MudTh>Thời gian</MudTh>
            <MudTh>Đã dùng</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd><MudText Color="Color.Secondary">@context.Name</MudText></MudTd>
            <MudTd><MudChip T="string" Size="Size.Small" Color="Color.Default">@context.Type</MudChip></MudTd>
            <MudTd>@FormatDiscount(context)</MudTd>
            <MudTd>@context.StartDate?.ToString("dd/MM") – @context.EndDate?.ToString("dd/MM/yyyy")</MudTd>
            <MudTd>@context.UsedCount lần</MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    class PromoModel
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public string Type { get; set; } = "";
        public double DiscountValue { get; set; }
        public string? Code { get; set; }
        public decimal MinOrderValue { get; set; }
        public DateTime? StartDate { get; set; }
        public DateTime? EndDate { get; set; }
        public string Description { get; set; } = "";
        public string Status { get; set; } = "";
        public int UsedCount { get; set; }
    }
    class PromoForm
    {
        public string Name { get; set; } = "";
        public string Type { get; set; } = "Giảm %";
        public double DiscountValue { get; set; }
        public string Code { get; set; } = "";
        public decimal MinOrderValue { get; set; }
        public DateTime? StartDate { get; set; } = DateTime.Today;
        public DateTime? EndDate { get; set; } = DateTime.Today.AddDays(7);
        public string Description { get; set; } = "";
    }

    List<PromoModel> _promos =
    [
        new() { Id = 1, Name = "Flash Sale Cuối Tuần", Type = "Giảm %", DiscountValue = 20, Code = "SALE20", MinOrderValue = 300000, StartDate = DateTime.Today.AddDays(-1), EndDate = DateTime.Today.AddDays(2), Description = "Giảm 20% toàn bộ áo thun", Status = "Đang chạy", UsedCount = 47 },
        new() { Id = 2, Name = "Miễn phí ship tháng 4", Type = "Free ship", DiscountValue = 0, MinOrderValue = 200000, StartDate = DateTime.Today.AddDays(-5), EndDate = DateTime.Today.AddDays(15), Description = "Miễn phí vận chuyển cho đơn từ 200k", Status = "Đang chạy", UsedCount = 123 },
        new() { Id = 3, Name = "Giảm 50k cho đơn đầu tiên", Type = "Giảm tiền", DiscountValue = 50000, Code = "NEWBIE50K", MinOrderValue = 250000, StartDate = DateTime.Today, EndDate = DateTime.Today.AddDays(30), Description = "Áp dụng cho khách hàng mới", Status = "Đang chạy", UsedCount = 18 },
        new() { Id = 4, Name = "Lễ 30/4 – Mua 2 tặng 1", Type = "Mua X tặng Y", DiscountValue = 0, StartDate = DateTime.Today.AddDays(5), EndDate = DateTime.Today.AddDays(8), Description = "Mua 2 sản phẩm bất kỳ tặng 1 phụ kiện", Status = "Sắp diễn ra", UsedCount = 0 },
        new() { Id = 5, Name = "Khai xuân 2025 – Giảm 15%", Type = "Giảm %", DiscountValue = 15, Code = "TET2025", MinOrderValue = 500000, StartDate = DateTime.Today.AddDays(10), EndDate = DateTime.Today.AddDays(17), Description = "Mừng xuân Ất Tỵ 2025", Status = "Sắp diễn ra", UsedCount = 0 },
        new() { Id = 6, Name = "Valentine's Day Sale", Type = "Giảm %", DiscountValue = 25, Code = "LOVE25", MinOrderValue = 400000, StartDate = new DateTime(2025, 2, 12), EndDate = new DateTime(2025, 2, 14), Description = "Giảm 25% quần áo cặp đôi", Status = "Đã kết thúc", UsedCount = 89 },
        new() { Id = 7, Name = "8/3 Tri ân phụ nữ", Type = "Quà tặng", DiscountValue = 0, Code = "WODAY83", MinOrderValue = 350000, StartDate = new DateTime(2025, 3, 6), EndDate = new DateTime(2025, 3, 8), Description = "Tặng hoa + thiệp cho đơn từ 350k", Status = "Đã kết thúc", UsedCount = 156 },
    ];

    bool _showForm;
    int? _editingId;
    PromoModel? _deletingItem;
    PromoForm _form = new();
    int _nextId = 8;

    IEnumerable<PromoModel> UpcomingPromos => _promos.Where(x => x.Status == "Sắp diễn ra");
    IEnumerable<PromoModel> EndedPromos => _promos.Where(x => x.Status == "Đã kết thúc");

    void OpenAddForm() { _editingId = null; _form = new PromoForm(); _showForm = true; }

    void OpenEditForm(PromoModel p)
    {
        _editingId = p.Id;
        _form = new PromoForm { Name = p.Name, Type = p.Type, DiscountValue = p.DiscountValue, Code = p.Code ?? "", MinOrderValue = p.MinOrderValue, StartDate = p.StartDate, EndDate = p.EndDate, Description = p.Description };
        _showForm = true;
    }

    void SavePromo()
    {
        var status = _form.StartDate > DateTime.Today ? "Sắp diễn ra" : (_form.EndDate < DateTime.Today ? "Đã kết thúc" : "Đang chạy");
        if (_editingId == null)
            _promos.Add(new PromoModel { Id = _nextId++, Name = _form.Name, Type = _form.Type, DiscountValue = _form.DiscountValue, Code = _form.Code, MinOrderValue = _form.MinOrderValue, StartDate = _form.StartDate, EndDate = _form.EndDate, Description = _form.Description, Status = status });
        else
        {
            var p = _promos.First(x => x.Id == _editingId);
            p.Name = _form.Name; p.Type = _form.Type; p.DiscountValue = _form.DiscountValue; p.Code = _form.Code;
            p.MinOrderValue = _form.MinOrderValue; p.StartDate = _form.StartDate; p.EndDate = _form.EndDate;
            p.Description = _form.Description; p.Status = status;
        }
        _showForm = false;
    }

    void DoDelete() { if (_deletingItem != null) { _promos.Remove(_deletingItem); _deletingItem = null; } }

    static string FormatDiscount(PromoModel p) => p.Type switch
    {
        "Giảm %" => $"{p.DiscountValue}%",
        "Giảm tiền" => $"₫ {p.DiscountValue:N0}",
        "Free ship" => "Miễn phí ship",
        _ => p.Type
    };

    static string GetPromoIcon(string type) => type switch
    {
        "Giảm %" => Icons.Material.Filled.Percent,
        "Giảm tiền" => Icons.Material.Filled.MoneyOff,
        "Free ship" => Icons.Material.Filled.LocalShipping,
        "Mua X tặng Y" => Icons.Material.Filled.CardGiftcard,
        "Quà tặng" => Icons.Material.Filled.Redeem,
        _ => Icons.Material.Filled.LocalOffer
    };
}
