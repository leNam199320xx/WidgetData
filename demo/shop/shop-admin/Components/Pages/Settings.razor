@page "/settings"
@using MudBlazor
@inject IStringLocalizer<SharedResource> L

<PageTitle>@L["Settings_Title"] - WidgetData</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">@L["Settings_Title"]</MudText>

<MudCard>
    <MudCardContent>
        <MudText Typo="Typo.body1">@L["Settings_Placeholder"]</MudText>
    </MudCardContent>
</MudCard>
