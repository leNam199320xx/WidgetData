@using MudBlazor

<MudCard Elevation="2" Style="@($"border-left: 4px solid {BorderColor}")">
    <MudCardContent>
        <div class="d-flex justify-space-between align-center">
            <div>
                <MudText Typo="Typo.h5" Color="@ValueColor">@Value</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">@Label</MudText>
                @if (!string.IsNullOrEmpty(Trend))
                {
                    <MudText Typo="Typo.caption" Color="@ValueColor">@Trend</MudText>
                }
            </div>
            @if (!string.IsNullOrEmpty(Icon))
            {
                <MudIcon Icon="@Icon" Color="@ValueColor" Style="font-size: 2.5rem; opacity: 0.3" />
            }
        </div>
    </MudCardContent>
</MudCard>

@code {
    [Parameter] public string Value { get; set; } = "";
    [Parameter] public string Label { get; set; } = "";
    [Parameter] public string? Trend { get; set; }
    [Parameter] public string? Icon { get; set; }
    [Parameter] public Color ValueColor { get; set; } = Color.Default;
    [Parameter] public string BorderColor { get; set; } = "#9e9e9e";
}
