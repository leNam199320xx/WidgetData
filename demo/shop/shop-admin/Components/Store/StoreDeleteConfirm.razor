@using MudBlazor

<MudPaper Class="pa-4 mb-4" Elevation="3" Style="border-left: 4px solid #f44336">
    <MudText Typo="Typo.h6" Color="Color.Error">Xác nhận xóa</MudText>
    <MudText Class="mb-3">@Message</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Error" OnClick="OnConfirm" Class="mr-2">Xóa</MudButton>
    <MudButton Variant="Variant.Outlined" OnClick="OnCancel">Hủy</MudButton>
</MudPaper>

@code {
    [Parameter] public string Message { get; set; } = "Bạn có chắc muốn xóa?";
    [Parameter] public EventCallback OnConfirm { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }
}
