{
  "title": "Liên hệ – VietNews",
  "layout": "flex",
  "auth": { "required": false },
  "widgets": [
    {
      "staticData": {
        "headline": "Liên hệ với VietNews",
        "subheadline": "Góp ý, cung cấp thông tin, hoặc liên hệ quảng cáo — chúng tôi luôn lắng nghe."
      },
      "template": "<div class=\"we-hero\" style=\"padding:48px 24px 40px;background:#fff5f5\"><h1 class=\"we-hero-headline\">{{headline}}</h1><p class=\"we-hero-subheadline\">{{subheadline}}</p></div>"
    },
    {
      "staticData": {
        "rows": [
          { "icon": "📧", "label": "Email tòa soạn",      "value": "toasoan@vietnews.vn" },
          { "icon": "📢", "label": "Hợp tác quảng cáo",   "value": "ads@vietnews.vn" },
          { "icon": "🕐", "label": "Giờ làm việc",          "value": "T2–T7, 7:00–19:00" },
          { "icon": "📍", "label": "Văn phòng",              "value": "54 Lý Thái Tổ, Hoàn Kiếm, Hà Nội" }
        ]
      },
      "template": "<div class=\"we-section\"><h2 class=\"we-section-title\" style=\"text-align:center;margin-bottom:28px\">Thông tin liên hệ</h2><div style=\"display:grid;grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:16px;max-width:800px;margin:0 auto\">{{#each rows}}<div style=\"background:#fff;border:1px solid #e2e8f0;border-radius:10px;padding:18px 20px;display:flex;align-items:flex-start;gap:12px\"><span style=\"font-size:26px\">{{icon}}</span><div><div style=\"font-size:11px;font-weight:700;color:#718096;text-transform:uppercase;letter-spacing:.5px;margin-bottom:4px\">{{label}}</div><div style=\"font-size:14px;font-weight:600;color:#1a202c\">{{value}}</div></div></div>{{/each}}</div></div>"
    },
    {
      "formId": 19,
      "title": "Gửi phản hồi"
    },
    {
      "staticData": {
        "title": "Cung cấp thông tin nóng",
        "desc": "Nếu bạn có thông tin quan trọng muốn chia sẻ với tòa soạn, hãy liên hệ qua đường dây nóng hoặc gửi email mã hóa. Chúng tôi đảm bảo bảo mật nguồn tin.",
        "hotline": "1800 1234 (miễn phí)",
        "email_secure": "secure@vietnews.vn (PGP)"
      },
      "template": "<div class=\"we-section\" style=\"background:#fff5f5;padding:40px 24px\"><div style=\"max-width:680px;margin:0 auto;text-align:center\"><h3 style=\"font-size:18px;font-weight:700;color:#c53030;margin:0 0 10px\">🔴 {{title}}</h3><p style=\"font-size:14px;color:#718096;margin:0 0 20px;line-height:1.6\">{{desc}}</p><div style=\"display:flex;justify-content:center;gap:24px;flex-wrap:wrap\"><div style=\"background:#fff;border:1px solid #fed7d7;border-radius:8px;padding:12px 20px\"><div style=\"font-size:12px;color:#e53e3e;font-weight:700;margin-bottom:4px\">📞 Đường dây nóng</div><div style=\"font-size:15px;font-weight:700;color:#1a202c\">{{hotline}}</div></div><div style=\"background:#fff;border:1px solid #fed7d7;border-radius:8px;padding:12px 20px\"><div style=\"font-size:12px;color:#e53e3e;font-weight:700;margin-bottom:4px\">🔒 Email bảo mật</div><div style=\"font-size:15px;font-weight:700;color:#1a202c\">{{email_secure}}</div></div></div></div></div>"
    }
  ]
}
